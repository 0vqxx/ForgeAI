# ─── Clerk (Auth IdP) ─────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com/ (your application → API Keys).
# VITE_ prefix exposes the publishable key to the browser bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk sign-in/up routes (defaults shown — Clerk init populates these automatically)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ─── Neon Postgres (Database) ─────────────────────────────────────────────────
# Connection string from the Neon console (Project → Dashboard → Connection Details).
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
